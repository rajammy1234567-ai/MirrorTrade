PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/mirror_trade
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8081
ADMIN_URL=http://localhost:5173

# Demo deposit without Razorpay — keep false for client production
ALLOW_FREE_DEPOSIT=false

# Razorpay Dashboard → Account & Settings → API Keys
# Use rzp_test_* keys for sandbox; rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
RAZORPAY_COMPANY_NAME=MirrorTrade
